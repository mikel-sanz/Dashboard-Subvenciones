# Configuración de Entorno
# Valores permitidos: development, production
ENV=development
LOG_LEVEL=INFO

# Persistencia
# Base de datos SQLite local o PostgreSQL cloud
DATABASE_URL=sqlite:///data/processed/subvenciones.db

# Autenticación y Seguridad
JWT_SECRET=super_secret_moriarty_key_2026
COOKIE_EXPIRY_DAYS=30

# Configuración de Ingesta y APIs
FORCE_SIMULATED_DATA=False
ALLOW_SIMULATED_FALLBACK=True

# Navarra CKAN Resource ID
NAVARRA_RESOURCE_ID=subvenciones_navarra_default_id

# Configuración SMTP (Alertas)
SMTP_SERVER=localhost
SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@dashboard-subvenciones.com

# Tareas Programadas y Analítica NLP
SCHEDULER_HOUR=6
AUTO_REFRESH_THRESHOLD_HOURS=24
USE_SEMANTIC_CLASSIFIER=True
NLP_MODEL_NAME=MoritzLaurer/mDeBERTa-v3-base-mnli-xnli
