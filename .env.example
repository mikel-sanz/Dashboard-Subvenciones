# Configuración de Entorno
# Valores permitidos: development, production
ENV=development
LOG_LEVEL=INFO

# Persistencia
# Base de datos SQLite local o PostgreSQL cloud
# Ejemplo PostgreSQL: postgresql://username:password@localhost:5432/dbname
DATABASE_URL=sqlite:///data/processed/subvenciones.db

# Autenticación y Seguridad
JWT_SECRET=super_secret_jwt_key_here
COOKIE_EXPIRY_DAYS=30

# Configuración de Ingesta y APIs
# Si se desea forzar el uso de datos simulados para pruebas, cambiar a True
FORCE_SIMULATED_DATA=False
# Permitir fallback automático a datos simulados si la API falla
ALLOW_SIMULATED_FALLBACK=True

# Navarra CKAN Resource ID (si se requiere apuntar a un dataset de subvenciones específico)
NAVARRA_RESOURCE_ID=subvenciones_navarra_default_id
